px; border-left: 4px solid #d32f2f; border-radius: 4px;\">\n      {{ JSON.parse($json.claude_analysis).root_cause.replace(/\\n/g, '<br>').replace(/\\*\\*(.*?)\\*\\*/g, '<strong>$1</strong>') }}\n    </p>\n\n    <h3 style=\"color: #d32f2f; border-bottom: 2px solid #d32f2f; padding-bottom: 6px;\">Attack Steps</h3>\n    <p style=\"background-color: #f9f9f9; padding: 12px; border-left: 4px solid #d32f2f; border-radius: 4px;\">\n      {{ JSON.parse($json.claude_analysis).attack_steps.replace(/\\n/g, '<br>').replace(/\\*\\*(.*?)\\*\\*/g, '<strong>$1</strong>') }}\n    </p>\n\n    <h3 style=\"color: #d32f2f; border-bottom: 2px solid #d32f2f; padding-bottom: 6px;\">Exploitation Conditions</h3>\n    <p style=\"background-color: #f9f9f9; padding: 12px; border-left: 4px solid #d32f2f; border-radius: 4px;\">\n      {{ JSON.parse($json.claude_analysis).exploitation_conditions.replace(/\\n/g, '<br>').replace(/\\*\\*(.*?)\\*\\*/g, '<strong>$1</strong>') }}\n    </p>\n\n    <h3 style=\"color: #d32f2f; border-bottom: 2px solid #d32f2f; padding-bottom: 6px;\">Risk Summary</h3>\n    <p style=\"background-color: #f9f9f9; padding: 12px; border-left: 4px solid #d32f2f; border-radius: 4px;\">\n      {{ JSON.parse($json.claude_analysis).risk_summary.replace(/\\n/g, '<br>').replace(/\\*\\*(.*?)\\*\\*/g, '<strong>$1</strong>') }}\n    </p>\n\n    <h3 style=\"color: #d32f2f; border-bottom: 2px solid #d32f2f; padding-bottom: 6px;\">Why Your System Is At Risk</h3>\n    <p style=\"background-color: #f9f9f9; padding: 12px; border-left: 4px solid #d32f2f; border-radius: 4px;\">\n      {{ $json.exploitability_reason.replace(/\\n/g, '<br>').replace(/\\*\\*(.*?)\\*\\*/g, '<strong>$1</strong>') }}\n    </p>\n\n    <h3 style=\"color: #1565c0; border-bottom: 2px solid #1565c0; padding-bottom: 6px;\">Patch Information</h3>\n    <table style=\"width: 100%; border-collapse: collapse;\">\n      <tr style=\"background-color: #f5f5f5;\">\n        <td style=\"padding: 8px 12px; font-weight: bold; width: 40%;\"