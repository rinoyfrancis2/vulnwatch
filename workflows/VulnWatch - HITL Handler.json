      "parameters": {
        "sendTo": "YOUR_EMAIL@gmail.com",
        "subject": "=🚨 CRITICAL CVE — Action Required: {{ $json.cve_id }}",
        "message": "=<!DOCTYPE html>\n<html>\n<body style=\"font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; padding: 20px; color: #333;\">\n\n  <div style=\"background-color: #b71c1c; padding: 15px; border-radius: 6px 6px 0 0;\">\n    <h2 style=\"color: white; margin: 0;\">🚨 CRITICAL CVE — Your Action Required</h2>\n  </div>\n\n  <div style=\"border: 1px solid #ddd; border-top: none; padding: 20px; border-radius: 0 0 6px 6px;\">\n\n    <table style=\"width: 100%; border-collapse: collapse; margin-bottom: 20px;\">\n      <tr style=\"background-color: #f5f5f5;\">\n        <td style=\"padding: 8px 12px; font-weight: bold; width: 40%;\">CVE ID</td>\n        <td style=\"padding: 8px 12px;\">{{ $json.cve_id }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 8px 12px; font-weight: bold;\">Software</td>\n        <td style=\"padding: 8px 12px;\">{{ $json.affected_software }} {{ $json.affected_version }}</td>\n      </tr>\n      <tr style=\"background-color: #f5f5f5;\">\n        <td style=\"padding: 8px 12px; font-weight: bold;\">CVSS Score</td>\n        <td style=\"padding: 8px 12px; color: #b71c1c; font-weight: bold;\">{{ $json.cvss_score }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 8px 12px; font-weight: bold;\">EPSS Score</td>\n        <td style=\"padding: 8px 12px;\">{{ $json.epss_score }}</td>\n      </tr>\n      <tr style=\"background-color: #f5f5f5;\">\n        <td style=\"padding: 8px 12px; font-weight: bold;\">KEV Listed</td>\n        <td style=\"padding: 8px 12px;\">{{ $json.kev_listed ? 'Yes — Actively Exploited' : 'No' }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 8px 12px; font-weight: bold;\">Patch Available</td>\n        <td style=\"padding: 8px 12px;\">{{ $json.patch_available ? 'Yes' : 'No — No patch exists' }}</td>\n      </tr>\n      <tr style=\"background-color: #f5f5f5;\">\n        <td style=\"padding: 8px 12px; font-weight: bold;\">PoC Exploit</td>\n        <td style=\"padding: 8px 12px;\">{{ $json.exploit_available ? 'Available' : 'Not found' }}</td>\n      </tr>\n    </table>\n\n    <h3 style=\"color: #b71c1c; border-bottom: 2px solid #b71c1c; padding-bottom: 6px;\">Root Cause</h3>\n    <p style=\"background-color: #f9f9f9; padding: 12px; border-left: 4px solid #b71c1c; border-radius: 4px;\">\n      {{ JSON.parse($json.claude_analysis).root_cause.replace(/\\n/g, '<br>').replace(/\\*\\*(.*?)\\*\\*/g, '<strong>$1</strong>') }}\n    </p>\n\n    <h3 style=\"color: #b71c1c; border-bottom: 2px solid #b71c1c; padding-bottom: 6px;\">Attack Steps</h3>\n    <p style=\"background-color: #f9f9f9; padding: 12px; border-left: 4px solid #b71c1c; border-radius: 4px;\">\n      {{ JSON.parse($json.claude_analysis).attack_steps.replace(/\\n/g, '<br>').replace(/\\*\\*(.*?)\\*\\*/g, '<strong>$1</strong>') }}\n    </p>\n\n    <h3 style=\"color: #b71c1c; border-bottom: 2px solid #b71c1c; padding-bottom: 6px;\">Exploitation Conditions</h3>\n    <p style=\"background-color: #f9f9f9; padding: 12px; border-left: 4px solid #b71c1c; border-radius: 4px;\">\n      {{ JSON.parse($json.claude_analysis).exploitation_conditions.replace(/\\n/g, '<br>').replace(/\\*\\*(.*?)\\*\\*/g, '<strong>$1</strong>') }}\n    </p>\n\n    <h3 style=\"color: #b71c1c; border-bottom: 2px solid #b71c1c; padding-bottom: 6px;\">Why Your System Is At Risk</h3>\n    <p style=\"background-color: #f9f9f9; padding: 12px; border-left: 4px solid #b71c1c; border-radius: 4px;\">\n      {{ $json.exploitability_reason.replace(/\\n/g, '<br>').replace(/\\*\\*(.*?)\\*\\*/g, '<strong>$1</strong>') }}\n    </p>\n\n    <h3 style=\"color: #b71c1c; border-bottom: 2px solid #b71c1c; padding-bottom: 6px;\">Risk Summary</h3>\n    <p style=\"background-color: #f9f9f9; padding: 12px; border-left: 4px solid #b71c1c; border-radius: 4px;\">\n      {{ JSON.parse($json.claude_analysis).risk_summary.replace(/\\n/g, '<br>').replace(/\\*\\*(.*?)\\*\\*/g, '<strong>$1</strong>') }}\n    </p>\n\n    <h3 style=\"color: #1565c0; border-bottom: 2px solid #1565c0; padding-bottom: 6px;\">Patch Information</h3>\n    <table style=\"width: 100%; border-collapse: collapse; margin-bottom: 20px;\">\n      <tr style=\"background-color: #f5f5f5;\">\n        <td style=\"padding: 8px 12px; font-weight: bold; width: 40%;\">Fixed Version</td>\n        <td style=\"padding: 8px 12px;\">{{ $json.fixed_version || 'None available' }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 8px 12px; font-weight: bold;\">Upgrade Command</td>\n        <td style=\"padding: 8px 12px; font-family: monospace; background-color: #f0f0f0; color: #1a1a1a; border-radius: 4px; padding: 10px;\">{{ $json.upgrade_command || 'N/A' }}</td>\n      </tr>\n      <tr style=\"background-color: #f5f5f5;\">\n        <td style=\"padding: 8px 12px; font-weight: bold;\">Workaround</td>\n        <td style=\"padding: 8px 12px;\">{{ $json.workaround || 'None documented' }}</td>\n      </tr>\n      <tr>\n        <td style=\"padding: 8px 12px; font-weight: bold;\">Advisory</td>\n        <td style=\"padding: 8px 12px;\"><a href=\"{{ $json.vendor_advisory_url }}\" style=\"color: #1565c0;\">{{ $json.vendor_advisory_url || 'Not available' }}</a></td>\n      </tr>\n    </table>\n\n    <h3 style=\"color: #1565c0; border-bottom: 2px solid #1565c0; padding-bottom: 6px;\">Choose Your Action</h3>\n\n    <div style=\"text-align: center; margin: 30px 0;\">\n      <a href=\"{{ $execution.resumeUrl }}&decision=A&cve_id={{ $json.cve_id }}\"\n         style=\"display: inline-block; margin: 8px; padding: 14px 24px; background-color: #2e7d32; color: white; text-decoration: none; border-radius: 6px; font-weight: bold;\">\n        A — Apply Workaround\n      </a>\n      <a href=\"{{ $execution.resumeUrl }}&decision=B&cve_id={{ $json.cve_id }}\"\n         style=\"display: inline-block; margin: 8px; padding: 14px 24px; background-color: #e65100; color: white; text-decoration: none; border-radius: 6px; font-weight: bold;\">\n        B — Monitor Only\n      </a>\n      <a href=\"{{ $execution.resumeUrl }}&decision=C&cve_id={{ $json.cve_id }}\"\n         style=\"display: inline-block; margin: 8px; padding: 14px 24px; background-color: #c62828; color: white; text-decoration: none; border-radius: 6px; font-weight: bold;\">\n        C — Ignore\n      </a>\n    </div>\n\n    <p style=\"margin-top: 30px; font-size: 12px; color: #999; text-align: center;\">\n      VulnWatch — Autonomous CVE Intelligence | Generated {{ $now.format('DD MMM YYYY HH:mm') }}\n    </p>\n\n  </div>\n</body>\n</html>\n",
        "options": {
          "appendAttribution": false
        }
      },
