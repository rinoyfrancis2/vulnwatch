    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const decision = $('Wait (hitl-response)').item.json.query.decision;\nconst cveId = $('Wait (hitl-response)').item.json.query.cve_id;\n\nconst config = {\n  'A': { icon: '🔧', label: 'Apply Workaround', bg: '#1a3a4a', color: '#63b3ed' },\n  'B': { icon: '👁️', label: 'Monitor Only',     bg: '#2a2a1a', color: '#ecc94b' },\n  'C': { icon: '🚫', label: 'Ignore',           bg: '#4a1515', color: '#fc8181' }\n}[decision] || { icon: '✅', label: decision, bg: '#1a2f23', color: '#68d391' };\n\n\nconst html = `<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>VulnWatch</title>\n  <style>\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    body { font-family: -apple-system, sans-serif; background: #0f1117; color: #e2e8f0; display: flex; align-items: center; justify-content: center; min-height: 100vh; }\n    .card { background: #1a1f2e; border: 1px solid #2d3748; border-radius: 12px; padding: 48px 40px; max-width: 460px; width: 90%; text-align: center; }\n    .icon { font-size: 52px; margin-bottom: 20px; }\n    h1 { font-size: 22px; color: #f7fafc; margin-bottom: 10px; }\n    .sub { color: #718096; font-size: 14px; margin-bottom: 28px; }\n    .badge { display: inline-block; padding: 8px 20px; border-radius: 20px; font-size: 14px; font-weight: 600; margin-bottom: 20px; background: ${config.bg}; color: ${config.color}; }\n    .cve { font-family: monospace; font-size: 13px; color: #68d391; background: #1a2f23; padding: 8px 16px; border-radius: 6px; display: inline-block; }\n    .footer { margin-top: 32px; font-size: 12px; color: #4a5568; }\n  </style>\n</head>\n<body>\n  <div class=\"card\">\n    <div class=\"icon\">${config.icon}</div>\n    <h1>Decision Recorded</h1>\n    <p class=\"sub\">VulnWatch has received your response.</p>\n    <div class=\"badge\">${config.label}</div>\n    <br/><br/>\n    <div class=\"cve\">${cveId}</div>\n    <p class=\"footer\">You can close this tab.</p>\n  </div>\n</body>\n</html>`;\n\nreturn { json: { html } };\n"
      },
